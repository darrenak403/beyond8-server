# Aspire / OpenTelemetry
ASPIRE_DASHBOARD_OTLP_API_KEY=your-otlp-api-key

# JWT
JWT_BEARER_SECRET_KEY=your-jwt-bearer-secret-key-minimum-32-characters-long

# Databases
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

IDENTITY_SERVICE_DATABASE=Identities
INTEGRATION_SERVICE_DATABASE=Integrations
ASSESSMENT_SERVICE_DATABASE=Assessments
CATALOG_SERVICE_DATABASE=Catalogs
LEARNING_SERVICE_DATABASE=Learnings
ANALYTIC_SERVICE_DATABASE=Analytics
SALE_SERVICE_DATABASE=Sales

# Hangfire (Identity, Integration, Sale each have a dedicated Hangfire DB in AppHost)
HANGFIRE_IDENTITY_DATABASE=HangfiresIdentity
HANGFIRE_INTEGRATION_DATABASE=HangfiresIntegration
HANGFIRE_SALE_DATABASE=HangfiresSale

# Redis
REDIS_PASSWORD=redis123

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# AWS (Shared - Integration: S3, Bedrock)
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=your-aws-region
AWS_S3_REGION=your-aws-region
AWS_BUCKET_NAME=your-aws-bucket-name
AWS_CLOUD_FRONT_URL=your-aws-cloud-front-url

# Ai Provider
AI_PROVIDER=Bedrock

# AWS Bedrock
AWS_BEDROCK_REGION=your-aws-bedrock-region
AWS_BEDROCK_DEFAULT_MODEL=your-aws-bedrock-default-model
AWS_BEDROCK_MAX_RETRIES=3
AWS_BEDROCK_TIMEOUT_SECONDS=30
AWS_BEDROCK_REQUESTS_PER_MINUTE=60
AWS_BEDROCK_REQUESTS_PER_DAY=1500
AWS_BEDROCK_MAX_CONCURRENT_REQUESTS=5

AWS_BEDROCK_DEFAULT_PARAMETERS_MAX_TOKENS=8192
AWS_BEDROCK_DEFAULT_PARAMETERS_TEMPERATURE=0.7
AWS_BEDROCK_DEFAULT_PARAMETERS_TOP_P=0.95
AWS_BEDROCK_DEFAULT_PARAMETERS_TOP_K=40

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_DEFAULT_MODEL=your-gemini-default-model
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_SECONDS=30
GEMINI_REQUESTS_PER_MINUTE=60
GEMINI_REQUESTS_PER_DAY=1500
GEMINI_MAX_CONCURRENT_REQUESTS=5

GEMINI_DEFAULT_PARAMETERS_MAX_TOKENS=8192
GEMINI_DEFAULT_PARAMETERS_TEMPERATURE=0.7
GEMINI_DEFAULT_PARAMETERS_TOP_P=0.95
GEMINI_DEFAULT_PARAMETERS_TOP_K=40

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=your-resend-from-email
RESEND_FROM_NAME=your-resend-from-name

# VNPT eKYC
VNPT_EKYC_BASE_URL=https://api.idg.vnpt.vn/
VNPT_EKYC_TIMEOUT_SECONDS=30
VNPT_EKYC_ACCESS_TOKEN=your-vnpt-ekyc-access-token
VNPT_EKYC_TOKEN_KEY=your-vnpt-ekyc-token-key
VNPT_EKYC_TOKEN_ID=your-vnpt-ekyc

# VNPay (Sale service - payment gateway)
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://beyond8.io.vn/payment/callback
VNPAY_BACKEND_CALLBACK_URL=https://api.beyond8.io.vn
VNPAY_PAYMENT_EXPIRY_MINUTES=15

# Optional: Hangfire (override worker count / dashboard path per service via appsettings)
# Hangfire__WorkerCount=4
# Hangfire__DashboardPath=/hangfire
